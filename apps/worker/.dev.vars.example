# Copy to `.dev.vars` for local `wrangler dev` (never commit `.dev.vars`).
# CI uses this file as-is for API integration tests.
#
# Cloudflare 側の認証情報はここには書きません。
# - 手元の wrangler: `pnpm exec wrangler login`（資格情報はユーザーディレクトリに保存）
# - D1 のバインド / database_id: 既定は `wrangler.toml`（プレースホルダ）。実 ID を Git に載せないなら
#   `wrangler.local.toml.example` を `wrangler.local.toml` にコピーして編集（gitignore 済み）。`pnpm dev`/`deploy` が優先利用。
# - CI デプロイ: リポジトリをプレースホルダのままにし、GitHub Secret `D1_DATABASE_ID` で注入（deploy-worker.yml）。
# - GitHub Actions デプロイ: リポジトリの Secrets（CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID）
# Worker のコードが読むのは下記のキーだけです。

API_KEY=local-dev-api-key-change-me
# Optional; defaults to API_KEY. HMAC secret for LINE Login OAuth `state` (use a long random value in production).
# LIFF_STATE_SECRET=
LINE_CHANNEL_SECRET=dev-placeholder
LINE_CHANNEL_ACCESS_TOKEN=dev-placeholder
LIFF_URL=https://liff.line.me/dev-placeholder
LINE_CHANNEL_ID=dev-placeholder
LINE_LOGIN_CHANNEL_ID=dev-placeholder
LINE_LOGIN_CHANNEL_SECRET=dev-placeholder
# Required for POST /api/integrations/stripe/webhook (HMAC signing). Use a test value locally.
STRIPE_WEBHOOK_SECRET=whsec_local_placeholder
# Optional; LINE に送るフォーム送信確認 Flex のフッター文言（未設定時は OSS デフォルト）
# FORM_SUBMIT_FLEX_FOOTER=
# Optional; 友だち追加時に不安カテゴリ選択ウェルカム Flex を返す（`1` / `true`）。postback `anxiety=*` の2通目は未設定でも処理。
# WELCOME_ANXIETY_FLOW=1
# LIFF_BOOKING_URL=
# WELCOME_ANXIETY_HERO_URL=
# WELCOME_ANXIETY_LINK_FLOW=
# WELCOME_ANXIETY_LINK_PREP=
# WELCOME_ANXIETY_LINK_FAQ=
# Optional; `1` で2通目 Flex に予約用ボタンを出さず、リッチメニュー誘導のみ（リッチメニュー予約メイン運用向け）。
# WELCOME_ANXIETY_RICH_MENU_ONLY=
