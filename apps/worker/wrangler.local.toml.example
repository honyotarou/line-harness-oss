# 実際の D1 database_id を Git に載せたくないとき:
#   cp wrangler.local.toml.example wrangler.local.toml
#   # database_id を編集（wrangler.local.toml は .gitignore 済み）
# pnpm dev / pnpm deploy は wrangler.local.toml を自動で使います。

name = "line-crm-worker"
main = "src/index.ts"
compatibility_date = "2024-12-01"
workers_dev = true

[vars]
# 実際の Cloudflare Worker URL と Vercel 管理画面 URL に差し替えてください。
WORKER_URL = "https://YOUR_SUBDOMAIN.workers.dev"
WEB_URL = "https://YOUR_PROJECT.vercel.app"
LIFF_URL = "https://liff.line.me/YOUR_LIFF_ID"

[[d1_databases]]
binding = "DB"
database_name = "line-crm"
database_id = "YOUR_D1_DATABASE_ID"

[triggers]
crons = ["*/5 * * * *"]
