{
  "name": "@line-crm/shared",
  "version": "0.2.0",
  "description": "Shared types and constants for LINE CRM",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./safe-api-base-url": {
      "types": "./dist/safe-api-base-url.d.ts",
      "import": "./dist/safe-api-base-url.js",
      "default": "./dist/safe-api-base-url.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "keywords": ["line", "crm", "types"]
}
