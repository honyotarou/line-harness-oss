{
  "name": "@line-crm/shared",
  "version": "0.2.0",
  "description": "Shared types and constants for LINE CRM",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./safe-api-base-url": {
      "types": "./dist/safe-api-base-url.d.ts",
      "import": "./dist/safe-api-base-url.js",
      "default": "./dist/safe-api-base-url.js"
    },
    "./allowed-origins": {
      "types": "./dist/allowed-origins.d.ts",
      "import": "./dist/allowed-origins.js",
      "default": "./dist/allowed-origins.js"
    },
    "./safe-liff-redirect": {
      "types": "./dist/safe-liff-redirect.d.ts",
      "import": "./dist/safe-liff-redirect.js",
      "default": "./dist/safe-liff-redirect.js"
    },
    "./admin-browser-client": {
      "types": "./dist/admin-browser-client.d.ts",
      "import": "./dist/admin-browser-client.js",
      "default": "./dist/admin-browser-client.js"
    },
    "./line-account-at-rest": {
      "types": "./dist/line-account-at-rest.d.ts",
      "import": "./dist/line-account-at-rest.js",
      "default": "./src/line-account-at-rest.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "keywords": ["line", "crm", "types"]
}
