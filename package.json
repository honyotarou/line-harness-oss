{
  "name": "line-oss-crm",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source LINE Official Account CRM/marketing automation",
  "scripts": {
    "dev:worker": "pnpm --filter worker dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --workspace-concurrency=1 -r build",
    "test": "pnpm --filter worker test && pnpm --filter web test && pnpm --filter @line-harness/sdk test",
    "test:coverage": "pnpm --filter worker test:coverage && pnpm --filter web test:coverage",
    "test:bench": "pnpm --filter worker test:bench",
    "test:e2e": "playwright test",
    "test:api": "bash scripts/api-integration.sh",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "harness": "bash scripts/harness-check.sh",
    "harness:ci": "bash scripts/harness-ci-parity.sh",
    "harness:full": "bash scripts/harness-full.sh",
    "db:migrate:worker-local": "pnpm --filter worker exec wrangler d1 execute line-crm --local --file=../../packages/db/schema.sql",
    "db:pre-010-check": "bash scripts/d1-pre-010-check.sh local",
    "db:pre-010-check:remote": "bash scripts/d1-pre-010-check.sh remote",
    "db:apply-010:local": "bash scripts/d1-apply-010.sh local",
    "smoke:staging": "bash scripts/liff-staging-smoke.sh",
    "deploy:worker": "pnpm --filter worker deploy",
    "deploy:web": "pnpm --filter web build",
    "db:migrate": "wrangler d1 execute line-crm --file=packages/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute line-crm --file=packages/db/schema.sql --local"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.51.1",
    "lefthook": "^1.11.14",
    "typescript": "^5.9.3"
  }
}
